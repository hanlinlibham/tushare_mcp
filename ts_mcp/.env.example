# Tushare MCP Server 环境变量配置示例
# 复制此文件为 .env 并填入实际的配置值

# Tushare API Token (必需)
# 从 https://tushare.pro/ 获取
TUSHARE_TOKEN=your_tushare_token_here

# 服务器配置
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8006
MCP_TRANSPORT=streamable-http

# Python环境
PYTHONUNBUFFERED=1
PYTHONPATH=/home/abmind_v01/data/src

# 日志配置
LOG_LEVEL=INFO
